            "custom_liquid_FBYfLa": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "<!-- LUXURY TRUST BOX (Black + Gold + White) -->\n<div class=\"lux-warranty-box\">\n  <ul class=\"lux-list\">\n    <li class=\"lux-item\">\n      <span class=\"lux-icon\" aria-hidden=\"true\">\n        <!-- Shield -->\n        <svg viewBox=\"0 0 24 24\" fill=\"none\">\n          <path d=\"M12 2l8 4v6c0 5-3.4 9.4-8 10-4.6-.6-8-5-8-10V6l8-4z\" stroke=\"currentColor\" stroke-width=\"2\"/>\n          <path d=\"M9 12l2 2 4-5\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </span>\n      <div class=\"lux-text\">\n        <div class=\"lux-title\">2 Year Machine Warranty</div>\n        <div class=\"lux-sub\">Premium coverage for movement performance.</div>\n      </div>\n    </li>\n\n    <li class=\"lux-item\">\n      <span class=\"lux-icon\" aria-hidden=\"true\">\n        <!-- Return -->\n        <svg viewBox=\"0 0 24 24\" fill=\"none\">\n          <path d=\"M7 7h7a6 6 0 110 12H9\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n          <path d=\"M9 9l-3-2 3-2\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </span>\n      <div class=\"lux-text\">\n        <div class=\"lux-title\">3-Day Return/Exchange for Defects</div>\n        <div class=\"lux-sub\">Fast resolution for verified manufacturing defects.</div>\n      </div>\n    </li>\n\n    <li class=\"lux-item\">\n      <span class=\"lux-icon\" aria-hidden=\"true\">\n        <!-- Wallet -->\n        <svg viewBox=\"0 0 24 24\" fill=\"none\">\n          <path d=\"M4 7a3 3 0 013-3h10a3 3 0 013 3v1H7a3 3 0 00-3 3v-1z\" stroke=\"currentColor\" stroke-width=\"2\"/>\n          <path d=\"M4 11a3 3 0 013-3h14v10a3 3 0 01-3 3H7a3 3 0 01-3-3V11z\" stroke=\"currentColor\" stroke-width=\"2\"/>\n          <path d=\"M17 14h3\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n        </svg>\n      </span>\n      <div class=\"lux-text\">\n        <div class=\"lux-title\">Cash-on-Delivery Available</div>\n        <div class=\"lux-sub\">With Rs1000 advance security deposit.</div>\n      </div>\n    </li>\n  </ul>\n</div>\n\n<style>\n/* You can paste this in Custom Liquid / Section / Theme CSS */\n.lux-warranty-box{\n  --gold: #d7b45a;     /* luxury gold */\n  --gold2:#f3d27a;     /* highlight gold */\n  --txt:  #ffffff;\n  --muted:rgba(255,255,255,.72);\n\n  width: 100%;\n  max-width: 720px;\n  padding: 18px 18px;\n  border-radius: 16px;\n  background:\n    radial-gradient(1200px 500px at 10% 0%, rgba(215,180,90,.12), transparent 55%),\n    radial-gradient(900px 400px at 95% 100%, rgba(243,210,122,.10), transparent 55%),\n    rgba(0,0,0,.55);\n  border: 1px solid rgba(215,180,90,.35);\n  box-shadow:\n    0 14px 40px rgba(0,0,0,.55),\n    inset 0 0 0 1px rgba(255,255,255,.04);\n  backdrop-filter: blur(8px);\n}\n\n.lux-list{\n  list-style: none;\n  margin: 0;\n  padding: 0;\n  display: grid;\n  gap: 12px;\n}\n\n.lux-item{\n  display: flex;\n  gap: 12px;\n  align-items: flex-start;\n  padding: 12px 12px;\n  border-radius: 14px;\n  background: linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));\n  border: 1px solid rgba(255,255,255,.06);\n  transition: transform .18s ease, border-color .18s ease, background .18s ease;\n}\n\n.lux-item:hover{\n  transform: translateY(-1px);\n  border-color: rgba(215,180,90,.35);\n  background: linear-gradient(180deg, rgba(215,180,90,.10), rgba(255,255,255,.02));\n}\n\n.lux-icon{\n  width: 40px;\n  height: 40px;\n  border-radius: 12px;\n  display: grid;\n  place-items: center;\n  color: var(--gold);\n  background: radial-gradient(circle at 30% 30%, rgba(243,210,122,.22), rgba(215,180,90,.08));\n  border: 1px solid rgba(215,180,90,.35);\n  box-shadow: 0 8px 18px rgba(0,0,0,.35);\n  flex: 0 0 40px;\n}\n\n.lux-icon svg{\n  width: 22px;\n  height: 22px;\n}\n\n.lux-text{ min-width: 0; }\n\n.lux-title{\n  color: var(--txt);\n  font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;\n  font-weight: 700;\n  font-size: 16px;\n  letter-spacing: .2px;\n}\n\n.lux-sub{\n  margin-top: 3px;\n  color: var(--muted);\n  font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;\n  font-weight: 400;\n  font-size: 13px;\n  line-height: 1.35;\n}\n\n/* Mobile */\n@media (max-width: 600px){\n  .lux-warranty-box{ padding: 16px; border-radius: 14px; }\n  .lux-item{ padding: 12px; }\n  .lux-title{ font-size: 15px; }\n  .lux-sub{ font-size: 12.5px; }\n}\n</style>"
